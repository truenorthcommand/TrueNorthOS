# TrueNorthOS Environment Variables
# Copy this file to .env and fill in your actual values

# REQUIRED: Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/truenorthos

# REQUIRED: Session secret (generate a random string)
SESSION_SECRET=your-long-random-secret-key-here

# AI Services - OpenRouter (Primary)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_REFERER=https://truenorthos.co.uk

# Alternative: OpenAI (if not using OpenRouter)
# OPENAI_API_KEY=sk-...

# Gmail/Email Notifications
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# 2FA / OTP
OTP_SECRET=base32-encoded-secret-min-32-chars-with-padding

# Google Calendar/Outlook (optional)
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
SENDGRID_API_KEY=your-sendgrid-key

# Stripe Payments (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notification Service (optional)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Object Storage / File Uploads (Railway/Supabase compatible)
STORAGE_BUCKET=truenorthos-uploads
STORAGE_ENDPOINT=https://your-storage-endpoint.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_REGION=us-east-1

# QuickBooks (not integrated yet)
# QUICKBOOKS_CLIENT_ID=...
# QUICKBOOKS_CLIENT_SECRET=...
# QUICKBOOKS_SANDBOX=true

# Gemini/Google AI (legacy, prefer OpenRouter)
# AI_INTEGRATIONS_GEMINI_API_KEY=...
# AI_INTEGRATIONS_GEMINI_BASE_URL=...

# Replit integrations (not required for Railway)
# REPL_ID=...
# REPL_SLUG=...
